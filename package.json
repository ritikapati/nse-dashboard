{
  "name": "nse-dashboard",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "scripts": {
    "start": "npm --prefix frontend run start",
    "start:frontend": "npm --prefix frontend run start",
    "start:backend": "npm --prefix backend run start",
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend run test",
    "install:all": "npm install && npm --prefix frontend install && npm --prefix backend install && npm --prefix database install",
    "download:index-csv": "npm --prefix database run download:index-csv",
    "import:index-valuations": "npm --prefix database run import:index-valuations",
    "rename:index-csv": "npm --prefix database run rename:index-csv",
    "update:index-valuations": "npm --prefix database run update:index-valuations",
    "migrate:postgres": "npm --prefix database run migrate:sqlite-to-postgres"
  }
}
